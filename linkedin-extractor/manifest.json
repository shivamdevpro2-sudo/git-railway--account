{
  "manifest_version": 3,
  "name": "LinkedIn Hiring Extractor",
  "version": "1.0",
  "description": "Extract LinkedIn hiring posts into a CRM Dashboard",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
