{
  "manifest_version": 3,
  "name": "Hiring Content Extractor",
  "version": "1.0.0",
  "description": "Extract emails, phone numbers and hiring context from any webpage.",
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ]
    }
  ]
}